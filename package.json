{
  "name": "trevlin-wedding-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node --env-file-if-exists=.env server-dist/server/index.js",
    "test:server": "npm run build:server && node --test server-dist/server/*.test.js"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@formspree/react": "^3.0.0",
    "@langchain/core": "^1.2.3",
    "@langchain/openai": "^1.5.5",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^5.1.0",
    "framer-motion": "^12.35.0",
    "helmet": "^8.1.0",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.1",
    "streamdown": "^2.3.0",
    "tailwind-merge": "^3.5.0",
    "usehooks-ts": "^3.1.1"
